{
  "consumer": {
    "name": "GrubUI"
  },
  "interactions": [
    {
      "description": "a payment request with a declined card",
      "providerStates": [
        {
          "name": "payment gateway is available"
        }
      ],
      "request": {
        "body": {
          "orderId": "ORD-PACTDECLINE",
          "payment": {
            "cardNumber": "4000000000000002",
            "cardholderName": "Jane Smith",
            "cvv": "123",
            "expiryDate": "12/30"
          }
        },
        "headers": {
          "Content-Type": "application/json"
        },
        "method": "POST",
        "path": "/api/payment"
      },
      "response": {
        "body": {
          "error": "Card declined by issuer",
          "success": false
        },
        "headers": {
          "Content-Type": "application/json"
        },
        "matchingRules": {
          "body": {
            "$.error": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.success": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            }
          }
        },
        "status": 402
      }
    },
    {
      "description": "a payment request without an orderId",
      "providerStates": [
        {
          "name": "payment gateway is available"
        }
      ],
      "request": {
        "body": {
          "payment": {
            "cardNumber": "4242424242424242",
            "cardholderName": "Jane Smith",
            "cvv": "123",
            "expiryDate": "12/30"
          }
        },
        "headers": {
          "Content-Type": "application/json"
        },
        "method": "POST",
        "path": "/api/payment"
      },
      "response": {
        "body": {
          "error": "Order ID is required"
        },
        "headers": {
          "Content-Type": "application/json"
        },
        "matchingRules": {
          "body": {
            "$.error": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            }
          }
        },
        "status": 400
      }
    },
    {
      "description": "a request for all menu items",
      "providerStates": [
        {
          "name": "menu items exist"
        }
      ],
      "request": {
        "method": "GET",
        "path": "/api/menu"
      },
      "response": {
        "body": {
          "items": [
            {
              "available": true,
              "category": "mains",
              "description": "Tender chicken in rich tomato-butter gravy, served with naan",
              "id": "M001",
              "imageEmoji": "🍛",
              "imageUrl": "https://images.unsplash.com/photo-1603894584373-5ac82b2ae398?w=400&h=300&fit=crop",
              "name": "Butter Chicken",
              "price": 280
            }
          ],
          "total": 1
        },
        "headers": {
          "Content-Type": "application/json"
        },
        "matchingRules": {
          "body": {
            "$.items": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type",
                  "min": 1
                }
              ]
            },
            "$.items[*]": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.items[*].available": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.items[*].category": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.items[*].description": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.items[*].id": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.items[*].imageEmoji": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.items[*].imageUrl": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.items[*].name": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.items[*].price": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "integer"
                }
              ]
            },
            "$.total": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "integer"
                }
              ]
            }
          }
        },
        "status": 200
      }
    },
    {
      "description": "a request for mains only",
      "providerStates": [
        {
          "name": "menu items exist"
        }
      ],
      "request": {
        "method": "GET",
        "path": "/api/menu",
        "query": {
          "category": [

{
  "name": "takeaway-saas",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "test": "jest --selectProjects unit integration --passWithNoTests",
    "test:unit": "jest --selectProjects unit --passWithNoTests",
    "test:integration": "jest --selectProjects integration --passWithNoTests",
    "test:api": "jest --selectProjects api --passWithNoTests",
    "test:contract": "jest --selectProjects contract --passWithNoTests",
    "test:pact:provider": "jest tests/contract/pact.provider.test.ts --passWithNoTests",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:smoke": "playwright test --grep @smoke",
    "test:e2e:a11y": "playwright test tests/e2e/accessibility.spec.ts",
    "test:all": "npm run test && npm run test:contract && npm run test:e2e",
    "allure:generate": "allure generate allure-results --clean -o allure-report",
    "allure:open": "allure open allure-report",
    "allure:serve": "allure serve allure-results",
    "lint": "eslint . --ext .ts,.tsx"
  },
  "dependencies": {
    "next": "^16.2.4",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "uuid": "^14.0.0"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.2",
    "@pact-foundation/pact": "^16.3.0",
    "@playwright/test": "^1.44.0",
    "@testing-library/jest-dom": "^6.4.2",
    "@testing-library/react": "^15.0.7",
    "@testing-library/user-event": "^14.5.2",
    "@types/jest": "^30.0.0",
    "@types/node": "^20.13.0",
    "@types/react": "^18.3.3",
    "@types/supertest": "^7.2.0",
    "@types/uuid": "^9.0.8",
    "allure-js-commons": "^3.7.1",
    "allure-playwright": "^3.7.1",
    "axe-playwright": "^2.2.2",
    "dotenv": "^17.4.2",
    "jest": "^29.7.0",
    "jest-allure2-reporter": "^1.2.1",
    "jest-environment-jsdom": "^30.3.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "supertest": "^7.2.2",
    "ts-jest": "^29.1.4",
    "typescript": "^5.4.5",
    "wait-on": "^9.0.5"
  }
}
